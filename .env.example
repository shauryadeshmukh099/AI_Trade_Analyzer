# ChartScope — Environment Variables
# Copy this to .env.local for local dev (never commit .env.local to git)
# Add these same keys in Vercel Dashboard → Project → Settings → Environment Variables

# ── AI Providers ─────────────────────────────────────────────
# Dev: Google Gemini free tier (get key at aistudio.google.com, no credit card)
GEMINI_API_KEY=

# Production: Anthropic Claude Vision (swap analyzeChart export in lib/analyzeChart.js)
ANTHROPIC_API_KEY=

# ── Future: Market Data ───────────────────────────────────────
# TwelveData for live XAUUSD / NSE equity prices (free tier available)
TWELVEDATA_API_KEY=

# ── App ───────────────────────────────────────────────────────
NODE_ENV=development
